    "Sustainability at Bosch",
    {
      "id": "33ae70eafafec90fd6ac5a1f107547e7",
      "type": "image",
      "index": 14,
      "tos_url": "https://assets.bosch.com/media/global/career/woman-in-suit_res_1280x720.webp",
      "original_url": "https://assets.bosch.com/media/global/career/woman-in-suit_res_1280x720.webp",
      "note": "",
      "alt": "A woman is wearing a tailored suit with a all over print which says \"CO2 neutral\"."
